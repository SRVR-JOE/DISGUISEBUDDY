{
  "name": "disguise-buddy-ui",
  "version": "1.0.0",
  "description": "Disguise Buddy — d3 server configuration manager",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "api": "tsx electron/dev-server.ts",
    "start": "concurrently --kill-others-on-fail \"tsx electron/dev-server.ts\" \"vite --open\"",
    "electron:dev": "concurrently \"tsc -p electron/tsconfig.json -w\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc -p electron/tsconfig.json && vite build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.disguise.buddy",
    "productName": "Disguise Buddy",
    "directories": {
      "output": "dist-installer"
    },
    "extraResources": [
      {
        "from": "../profiles",
        "to": "profiles",
        "filter": [
          "**/*.json"
        ]
      },
      {
        "from": "../software",
        "to": "software",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true
    }
  }
}
